<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chess Champion</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap');

        body {
            font-family: 'Outfit', sans-serif;
        }

        .chessboard {
            display: grid;
            grid-template-columns: repeat(8, minmax(0, 1fr));
            grid-template-rows: repeat(8, minmax(0, 1fr));
            width: 400px;
            height: 400px;
        }

        .piece.white {
            color: white;
            filter: drop-shadow(0 0 2px rgba(0, 0, 0, 1));
        }

        .piece.black {
            color: black;
        }

        .flipped {
            transform: rotate(180deg);
        }

        .square {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .square.light {
            background-color: #f0d9b5;
        }

        .square.dark {
            background-color: #b58863;
        }

        .piece {
            font-size: 38px;
            cursor: pointer;
            transition: transform 0.15s ease;
        }

        .piece:hover {
            transform: scale(1.1);
        }

        .piece.draggable {
            cursor: grab;
        }

        .dragging {
            opacity: 0.5;
        }

        .flipped .piece {
            transform: rotate(180deg);
        }

        /* ── Captured Pieces Panel ── */
        .captured-panel {
            width: 130px;
            min-height: 420px;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 20px;
            backdrop-filter: blur(12px);
            padding: 14px 10px;
            display: flex;
            flex-direction: column;
            gap: 14px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.5);
        }

        .captured-section-title {
            font-size: 10px;
            font-weight: 600;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.35);
            text-align: center;
        }

        .captured-section {
            display: flex;
            flex-direction: column;
            gap: 6px;
            flex: 1;
        }

        .captured-section-label {
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            padding: 4px 8px;
            border-radius: 8px;
            text-align: center;
        }

        .label-white {
            background: rgba(255,255,255,0.1);
            color: rgba(255,255,255,0.7);
        }

        .label-black {
            background: rgba(0,0,0,0.3);
            color: rgba(255,255,255,0.5);
        }

        .captured-pieces-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 2px;
            min-height: 60px;
            padding: 6px;
            background: rgba(0,0,0,0.2);
            border-radius: 10px;
            align-content: flex-start;
        }

        .cap-piece {
            font-size: 22px;
            line-height: 1;
            animation: popIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
            filter: drop-shadow(0 1px 3px rgba(0,0,0,0.8));
        }

        @keyframes popIn {
            from { transform: scale(0) rotate(-20deg); opacity: 0; }
            to   { transform: scale(1) rotate(0deg);   opacity: 1; }
        }

        .divider {
            height: 1px;
            background: rgba(255,255,255,0.07);
            margin: 0 4px;
        }
    </style>
</head>

<body class="m-0 p-0 text-white overflow-hidden">
    <div class="w-full h-screen flex flex-col items-center justify-center bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-zinc-800 via-neutral-900 to-black gap-6">
        
        <!-- Game Title Header -->
        <div class="flex flex-col items-center gap-1">
            <h1 class="text-3xl font-extrabold tracking-wider bg-clip-text text-transparent bg-gradient-to-r from-amber-200 via-yellow-400 to-amber-500 drop-shadow-[0_2px_10px_rgba(245,158,11,0.2)]">
                CHESS CHAMPION
            </h1>
            <p class="text-xs text-zinc-400 font-mono tracking-widest uppercase opacity-80">Multiplayer Arena</p>
        </div>
        
        <!-- Board + Captured Panel layout -->
        <div class="flex items-center gap-6">

            <!-- Glassmorphism Board Card -->
            <div class="relative p-4 rounded-3xl bg-zinc-900/40 border border-zinc-800/80 shadow-[0_25px_60px_rgba(0,0,0,0.9)] backdrop-blur-lg">
                <!-- Glow effect behind board -->
                <div class="absolute -inset-1 rounded-3xl bg-gradient-to-r from-amber-500/10 to-yellow-600/10 blur-xl -z-10"></div>
                <!-- Chessboard -->
                <div class="chessboard rounded-2xl overflow-hidden shadow-[inset_0_4px_20px_rgba(0,0,0,0.6)]"></div>
            </div>

            <!-- Captured Pieces Panel -->
            <div class="captured-panel">
                <p class="captured-section-title">⚔️ Captured</p>

                <!-- White Player's Captures (black pieces) -->
                <div class="captured-section">
                    <div class="captured-section-label label-white">White</div>
                    <div class="captured-pieces-grid" id="captured-by-white"></div>
                </div>

                <div class="divider"></div>

                <!-- Black Player's Captures (white pieces) -->
                <div class="captured-section">
                    <div class="captured-section-label label-black">Black</div>
                    <div class="captured-pieces-grid" id="captured-by-black"></div>
                </div>
            </div>

        </div>

    </div>

    <script src="https://cdn.socket.io/4.8.3/socket.io.min.js"
        integrity="sha384-kzavj5fiMwLKzzD1f8S7TeoVIEi7uKHvbTA3ueZkrzYq75pNQUiUi6Dy98Q3fxb0"
        crossorigin="anonymous"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/chess.js/0.10.3/chess.min.js"
        integrity="sha512-xRllwz2gdZciIB+AkEbeq+gVhX8VB8XsfqeFbUh+SzHlN96dEduwtTuVuc2u9EROlmW9+yhRlxjif66ORpsgVA=="
        crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script src="/js/chessgame.js"></script>
</body>

</html>